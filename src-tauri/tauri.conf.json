{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalPlayer",
  "version": "0.4.0",
  "identifier": "com.localplayer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1450",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalPlayer",
        "width": 1180,
        "height": 720,
        "minWidth": 720,
        "minHeight": 460,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "fileAssociations": [
      {
        "ext": ["mp4", "mkv", "webm", "avi", "mov", "m4v", "mpg", "mpeg", "flv", "ts", "wmv"],
        "description": "Vídeo",
        "role": "Viewer"
      },
      {
        "ext": ["mp3", "flac", "m4a", "ogg", "opus", "wav", "aac", "wma"],
        "description": "Áudio",
        "role": "Viewer"
      }
    ],
    "resources": ["binaries/mpv/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
